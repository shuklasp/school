<?xml version="1.0" encoding="UTF-8"?>

<!--
    Document   : sppajax.module.xml
    Author     : Satya Prakash Shukla
    Description:
        SPA (Single Page Application) engine for SPP.
        Handles page fragment loading and service dispatch.
-->

<module>
    <name>sppajax</name>
    <version>1.0</version>
    <pubname>SPP Ajax / SPA Router</pubname>
    <modgroup>SPP_Core</modgroup>
    <pubdesc>Single Page Application engine. Handles page fragment and service dispatch via AJAX.</pubdesc>
    <includes>
        <include>class.sppajax.php</include>
    </includes>
    <deps>
        <depends>sppconfig</depends>
        <depends>sppview</depends>
    </deps>
</module>