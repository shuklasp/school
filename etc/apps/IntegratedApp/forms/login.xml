<?xml version="1.0" encoding="UTF-8"?>
<form name="login_form" action="" method="post" id="login_form">
    <controls>
        <control name="username" type="SPPText" label="Username" id="username" />
        <control name="password" type="SPPPassword" label="Password" id="password" />
        <control name="submit" type="SPPSubmit" value="Login" id="submit" />
    </controls>
    <validations>
        <validation control="username" type="SPPRequiredValidator" message="Username is required" />
        <validation control="password" type="SPPRequiredValidator" message="Password is required" />
    </validations>
</form>