{#
/**
 * @file
 * Theme implementation for the higher education landing page.
 * Exact structural match to the vshiksha.com archive.
 */
#}
<div class="layout-container section-higher-ed">
  <header class="site-header" role="banner">
    <div class="container header-inner">
      <div class="site-logo">
        <a href="{{ front_page }}" title="{{ 'Home'|t }}" rel="home" class="site-name">
          {{ site_name|default('Virtual Shiksha') }}
        </a>
      </div>
      
      {% if page.primary_menu %}
        <nav class="main-navigation" role="navigation">
          {{ page.primary_menu }}
        </nav>
      {% endif %}
    </div>
  </header>

  <main role="main">
    <div class="container">
      
      <h1 class="page-title" style="margin-top: 30px; font-size: 38px; color: var(--color-primary); border-bottom: 2px solid var(--color-border); padding-bottom: 15px;">Higher Education</h1>

      <div class="main-layout">
        
        <aside class="region-sidebar" role="complementary">
          {% if page.sidebar_first %}
            {{ page.sidebar_first }}
          {% else %}
            <div class="sidebar-block">
              <h2 class="block-title">Discover</h2>
              <div class="block-content">
                <ul class="sidebar-menu">
                  <li><a href="#">University Rankings</a></li>
                  <li><a href="#">Entrance Exams</a></li>
                  <li><a href="#">Admissions Guide</a></li>
                  <li><a href="#">Fellowships</a></li>
                </ul>
              </div>
            </div>
          {% endif %}
        </aside>

        <div class="region-content">
          {{ page.content }}
          
          {% if not page.content|render|trim %}
            <article class="node-teaser">
              <h2 class="node-title"><a href="#">Top University Rankings 2026</a></h2>
              <div class="node-meta">
                <span><i class="fa fa-folder-open"></i> Admission News</span>
              </div>
              <div class="node-content">
                <p>A comprehensive analysis of the top-performing institutions globally and what makes them stand out in terms of research output and placement records.</p>
              </div>
              <a href="#" class="read-more-link">Read Report</a>
              <div style="clear: both;"></div>
            </article>

            <article class="node-teaser">
              <h2 class="node-title"><a href="#">Guide to Post-Graduate Fellowships</a></h2>
              <div class="node-meta">
                <span><i class="fa fa-folder-open"></i> Career Advisory</span>
              </div>
              <div class="node-content">
                <p>Everything you need to know about preparing your application for competitive research fellowships like JRF, Fulbright, and Commonwealth.</p>
              </div>
              <a href="#" class="read-more-link">View Guide</a>
              <div style="clear: both;"></div>
            </article>

            <article class="node-teaser">
              <h2 class="node-title"><a href="#">Navigating International Student Visas</a></h2>
              <div class="node-meta">
                <span><i class="fa fa-folder-open"></i> Study Abroad</span>
              </div>
              <div class="node-content">
                <p>A step-by-step updated guide for students looking to pursue degrees abroad in popular destinations such as USA, UK, Canada, and Australia.</p>
              </div>
              <a href="#" class="read-more-link">Learn More</a>
              <div style="clear: both;"></div>
            </article>
          {% endif %}
        </div>

      </div>
    </div>
  </main>

  <footer class="site-footer" role="contentinfo">
    <div class="container">
      <div class="footer-bottom">
        <p>&copy; {{ "now"|date("Y") }} Virtual Shiksha. All rights reserved.</p>
      </div>
    </div>
  </footer>
</div>
